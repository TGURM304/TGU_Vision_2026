#!/bin/bash

export MVCAM_SDK_PATH="@HIKROBOTIC_SDK_INSTALL_PREFIX@"
export MVCAM_SDK_VERSION="@HIKROBOTIC_SDK_VERSION@"
export MVCAM_COMMON_RUNENV="$MVCAM_SDK_PATH/lib"
export MVCAM_GENICAM_CLPROTOCOL="$MVCAM_SDK_PATH/lib/CLProtocol"
export ALLUSERSPROFILE"=$MVCAM_SDK_PATH/MVFG"
export LD_LIBRARY_PATH="$MVCAM_SDK_PATH/lib/64:$LD_LIBRARY_PATH"

exec "$@"
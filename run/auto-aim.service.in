[Unit]
Description=Run auto aim
After=local-fs.target

[Service]
Type=simple
WorkingDirectory=@CMAKE_INSTALL_PREFIX@
ExecStart=/bin/bash bin/run.sh bin/standard_mpc --config-path configs/standard.yaml

# 日志输出到 journal
StandardOutput=journal
StandardError=journal

# 异常退出自动重启
Restart=on-failure
RestartSec=2s

[Install]
WantedBy=multi-user.target